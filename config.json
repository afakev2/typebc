// الكلمة التي سيرسلها البوت
BOT_WORD: "تم استلام الطلب"

// وقت التكرار (بالثواني)
// 60 = دقيقة
// 300 = 5 دقائق  
// 1800 = نصف ساعة
// 3600 = ساعة
RESEND_TIME_SECONDS: 1800

// نظام الحماية (يمنع اكتشاف البوت)
AUTO_STOP: {
    ENABLED: true,  // شغال
    WORK_TIME_MINUTES: 60,   // يشتغل ساعة
    REST_TIME_MINUTES: 180,  // يقعد 3 ساعات (يتخفى)
}

// مثال آخر:
// يشتغل 20 دقيقة ويقعد 40 دقيقة
WORK_TIME_MINUTES: 20,
REST_TIME_MINUTES: 40,

// يشتغل ساعتين ويقعد ساعة
WORK_TIME_MINUTES: 120,
REST_TIME_MINUTES: 60,
